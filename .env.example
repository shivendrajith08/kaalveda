# KaalVeda — environment variables (ALL OPTIONAL)
#
# The app runs with ZERO backend setup. Auth and bookmarks transparently
# fall back to localStorage when these are absent. Provide them only if you
# want cross-device sync via Supabase.

# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key
